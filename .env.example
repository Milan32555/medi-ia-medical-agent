# MEDI-IA — Variables de entorno
# Copia este archivo a .env y completa tus valores

# API Key de Anthropic (Claude)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Modelo de Claude a usar
# Opciones: claude-haiku-4-5-20251001 (rapido/barato) | claude-sonnet-4-6 (mejor calidad)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Puerto del servidor Flask
PORT=5000

# Modo debug de Flask (False en produccion)
FLASK_DEBUG=False
